<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Scheduled action to run fetch_usd_inr_rate every day at 11:00 AM -->
    <record id="ir_cron_currency_rate_updater" model="ir.cron">
        <field name="name">Fetch USD to INR Rate</field>
        <field name="model_id" ref="base.model_res_currency"/>
        <field name="state">code</field>
        <field name="code">model.fetch_usd_inr_rate()</field>
        <field name="active">True</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall">True</field>
        <field name="nextcall">2025-10-16 05:30:00</field> <!-- UTC time -->
    </record>
</odoo>

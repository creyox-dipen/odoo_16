<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="0">
    <record id="payment_provider_nmi" model="payment.provider">
        <field name="name">NMI</field>
        <field name="image_128" type="base64" file="cr_payment_nmi_integration/static/description/icon.png"/>
        <field name="code">nmi</field>
        <field name="redirect_form_view_id" eval="False"/>
        <field name="inline_form_view_id" ref="inline_form"/>
        <field name="allow_tokenization">True</field>
        <field name="module_id" ref="base.module_cr_payment_nmi_integration"/>
        <field name="payment_icon_ids"
               eval="[Command.set([
                          ref('payment.payment_icon_cc_visa'),
                          ref('payment.payment_icon_cc_mastercard'),
                          ref('payment.payment_icon_cc_american_express'),
                          ref('payment.payment_icon_cc_discover'),
                      ])]"
        />
        <field name="company_id" ref="base.main_company"/>
    </record>
</odoo>

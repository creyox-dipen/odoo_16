<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">NMI Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='provider_credentials']" position="inside">
                <group attrs="{'invisible': [('code', '!=', 'nmi')]}">
                    <field name="nmi_security_key"
                           attrs="{'required': [('code', '=', 'nmi'), ('state', '!=', 'disabled')]}"
                           password="True"/>
                    <field name="nmi_v4_api_key"
                           attrs="{'required': [('code', '=', 'nmi'), ('state', '!=', 'disabled')]}"
                           password="True"/>
                </group>
            </xpath>

            <xpath expr="//page[@name='configuration']//group[@name='payment_followup']" position="after">
                <group string="NMI Card Surcharges" attrs="{'invisible': [('code', '!=', 'nmi')]}">
                    <field name="is_nmi_card_fee"/>
                    <field name="nmi_credit_card_fee"
                           attrs="{'invisible': [('is_nmi_card_fee', '=', False)], 'required': [('is_nmi_card_fee', '=', True)]}"/>
                    <field name="nmi_debit_card_fee"
                           attrs="{'invisible': [('is_nmi_card_fee', '=', False)], 'required': [('is_nmi_card_fee', '=', True)]}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

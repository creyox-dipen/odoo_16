<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_picking_form_inherit_channable" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit.channable</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <!--
                    Only show the Channable tab on outgoing deliveries
                    that originated from a Channable sale order.
                -->
                <xpath expr="//notebook" position="before">
                    <field name="picking_type_code" invisible="1"/>
                    <field name="channable_marketplace_id" invisible="1"/>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page string="Channable"
                          name="channable_picking_info"
                          attrs="{'invisible': ['|', '|', ('picking_type_code', '!=', 'outgoing'), ('sale_id', '=', False), ('channable_marketplace_id', '=', False)]}">
                        <field name="sale_id" invisible="1"/>
                        <group>
                            <field name="channable_sync_status" readonly="1"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
